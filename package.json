{
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@symfony/webpack-encore": "^6.0.0",
        "bootstrap": "^5.3.8",
        "date-fns": "^4.1.0",
        "eslint-webpack-plugin": "^6.0.0",
        "glob": "^13.0.6",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.2",
        "purgecss-webpack-plugin": "^8.0.0",
        "sass": "^1.99.0",
        "sass-loader": "^16.0.7",
        "webpack": "^5.106.1",
        "webpack-cli": "^6.0.1"
    },
    "license": "MIT",
    "private": true,
    "scripts": {
        "prepare": "husky install",
        "dev-server": "encore dev-server",
        "dev": "encore dev",
        "watch": "encore dev --watch",
        "build": "encore production",
        "prettier": "prettier --write '**/*.{js,json,scss,css,md}'",
        "prettier:ci": "prettier --check '**/*.{js,json,scss,css,md}'",
        "eslint": "eslint ."
    },
    "lint-staged": {
        "*.js": [
            "eslint",
            "prettier --write"
        ],
        "*.{json,scss,css,md}": [
            "prettier --write"
        ]
    },
    "type": "module"
}
